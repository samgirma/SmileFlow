# =================================
# SmileFlow Client - Production Environment Variables
# =================================

# API Configuration (Required)
VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_TIMEOUT=30000

# Authentication (Required)
VITE_AUTH_ENDPOINT=/auth
VITE_TOKEN_STORAGE_KEY=sf_token
VITE_USER_STORAGE_KEY=sf_user

# External Services
VITE_AI_SERVICE_URL=https://ai.smileflow.com/api
VITE_AI_SERVICE_KEY=your_ai_service_key_here
VITE_AI_MODEL=gpt-4

# Analytics & Monitoring
VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
VITE_SENTRY_DSN=your_sentry_dsn_here

# Payment & Billing
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_key_here

# Image & Media Services
VITE_IMAGE_CDN_URL=https://cdn.smileflow.com
VITE_IMAGE_PLACEHOLDER_URL=https://images.unsplash.com

# Feature Flags
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
